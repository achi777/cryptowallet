# Copy to .env and fill in real values for `docker compose -f docker-compose.yml -f docker-compose.prod.yml up`.
# .env is gitignored — never commit real secrets.

# Postgres bootstrap creds (used by the postgres image and 01-init.sql role provisioning).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me

# Application DB user (cryptouser). Must match what 01-init.sql provisions for the cryptouser role.
SPRING_DATASOURCE_USERNAME=cryptouser
SPRING_DATASOURCE_PASSWORD=replace-me

# Master key-encryption-key — 32 raw bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
# REQUIRED for the prod profile. Loss of this value means encrypted-at-rest data is unrecoverable.
CRYPTOWALL_KEK_BASE64=replace-me

# Optional — first-time admin bootstrap password (consumed once by AdminService on cold start).
ADMIN_BOOTSTRAP_PASSWORD=
